      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "npx tsc --build && rollup -c",
    "test": "vitest run",
    "test:e2e": "playwright test",
