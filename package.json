{
  "name": "@monoscopetech/browser",
  "version": "0.7.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "unpkg": "dist/monoscope.umd.js",
  "browser": "dist/monoscope.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
